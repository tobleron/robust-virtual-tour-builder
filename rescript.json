{
    "name": "robust-virtual-tour-builder",
    "sources": [
        {
            "dir": "src",
            "subdirs": true
        },
        {
            "dir": "tests",
            "subdirs": true,
            "type": "dev"
        }
    ],
    "package-specs": {
        "module": "es6",
        "in-source": true
    },
    "suffix": ".bs.js",
    "jsx": {
        "version": 4,
        "mode": "automatic"
    },
    "dependencies": [
        "@rescript/react",
        "rescript-vitest",
        "@glennsl/rescript-json-combinators"
    ],
    "warnings": {
        "error": "+A"
    }
}