JWT_SECRET=dev-secret-key-12345-long-enough-for-security-purposes-12345678
SESSION_KEY=dev-session-key-12345-very-long-key-to-satisfy-cookie-secure-key-requirements-64-bytes-long
BYPASS_AUTH=true
NODE_ENV=production
DATABASE_URL=sqlite://data/database.db
STORAGE_PATH=./storage
LOG_LEVEL=info
LOG_DIR=./logs
TEMP_DIR=./temp
SESSIONS_DIR=./sessions
ALLOW_DISK_CHECK_BYPASS=true
CORS_ALLOWED_ORIGINS=http://www.robust-vtb.com,https://www.robust-vtb.com,https://robust-vtb.com
