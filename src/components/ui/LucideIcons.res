/* src/components/ui/LucideIcons.res */

// Lucide React icon bindings for ReScript
// Icons are imported as React components

module Play = {
  @module("lucide-react") @react.component
  external make: (
    ~className: string=?,
    ~size: int=?,
    ~strokeWidth: float=?,
    ~fill: string=?,
  ) => React.element = "Play"
}

